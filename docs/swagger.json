        "/bookings/create": {
            "post": {
                "description": "Доступно только роли user. Администратор не может создавать брони (403). userId берётся из JWT-токена, а не из тела запроса. Если временной слот находится в прошлом (start \u003c now), возвращается 400 (INVALID_REQUEST).",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Bookings"
                ],
                "summary": "Создать бронь на слот (только user). Опционально — запросить ссылку на конференцию.",
                "parameters": [
                    {
                        "description": "тело запроса",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/internal_features_bookings_transport_http.SlotDTO"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Бронь создана",
                        "schema": {
                            "$ref": "#/definitions/internal_features_bookings_transport_http.BookingDTOResponse"
                        }
                    },
                    "400": {
                        "description": "Неверный запрос",
                        "schema": {
                            "$ref": "#/definitions/backend-assignment-avito_internal_core_domain.CustomError"
                        }
                    },
                    "401": {
                        "description": "Не авторизован",
                        "schema": {
                            "$ref": "#/definitions/backend-assignment-avito_internal_core_domain.CustomError"
                        }
                    },
                    "403": {
                        "description": "Доступ запрещён (бронирование доступно только роли user)",
                        "schema": {
                            "$ref": "#/definitions/backend-assignment-avito_internal_core_domain.CustomError"
                        }
                    },
                    "404": {
                        "description": "Слот не найден",
                        "schema": {
                            "$ref": "#/definitions/backend-assignment-avito_internal_core_domain.CustomError"
                        }
                    },
                    "409": {
                        "description": "Слот уже занят",
                        "schema": {
                            "$ref": "#/definitions/backend-assignment-avito_internal_core_domain.CustomError"
                        }
                    },
                    "500": {
                        "description": "Внутренняя ошибка сервера",
                        "schema": {
                            "$ref": "#/definitions/backend-assignment-avito_internal_core_domain.CustomError"
                        }
                    }
                }
            }
        },
        "/bookings/list": {
            "get": {
                "description": "Доступно только роли admin. Поддерживает пагинацию через параметры page и pageSize. Оба параметра опциональны; значения по умолчанию: page=1, pageSize=20. Максимальное значение pageSize — 100.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Bookings"
                ],
                "summary": "Список всех броней с пагинацией (только admin)",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Номер страницы (начиная с 1). По умолчанию 1.",
                        "name": "page",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "Количество записей на странице. По умолчанию 20, максимум 100.",
                        "name": "pageSize",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Cписок всех броней",
                        "schema": {
                            "$ref": "#/definitions/internal_features_bookings_transport_http.BookingsDTOWithPagination"
                        }
                    },
                    "400": {
                        "description": "Неверный запрос (некорректные параметры пагинации)",
                        "schema": {
                            "$ref": "#/definitions/backend-assignment-avito_internal_core_domain.CustomError"
                        }
                    },
                    "401": {
                        "description": "Не авторизован",
                        "schema": {
                            "$ref": "#/definitions/backend-assignment-avito_internal_core_domain.CustomError"
                        }
                    },
                    "403": {
                        "description": "Доступ запрещён (только admin)",
                        "schema": {
                            "$ref": "#/definitions/backend-assignment-avito_internal_core_domain.CustomError"
                        }
                    },
                    "500": {
                        "description": "Внутренняя ошибка сервера",
                        "schema": {
                            "$ref": "#/definitions/backend-assignment-avito_internal_core_domain.CustomError"
                        }
                    }
                }
            }
        },
        "/bookings/my": {
            "get": {
                "description": "Доступно только роли user. Возвращает брони пользователя, чей user_id содержится в JWT-токене. Возвращаются только брони на будущие слоты (start \u003e= now); брони на уже прошедшие слоты в ответ не включаются.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Bookings"
                ],
                "summary": "Список броней текущего пользователя (только user)",
                "responses": {
                    "200": {
                        "description": "Список броней текущего пользователя",
                        "schema": {
                            "$ref": "#/definitions/internal_features_bookings_transport_http.BookingsDTOResponse"
                        }
                    },
                    "401": {
                        "description": "Не авторизован",
                        "schema": {
                            "$ref": "#/definitions/backend-assignment-avito_internal_core_domain.CustomError"
                        }
                    },
                    "403": {
                        "description": "Доступ запрещён (только user)",
                        "schema": {
                            "$ref": "#/definitions/backend-assignment-avito_internal_core_domain.CustomError"
                        }
                    },
                    "500": {
                        "description": "Внутренняя ошибка сервера",
                        "schema": {
                            "$ref": "#/definitions/backend-assignment-avito_internal_core_domain.InternalError"
                        }
                    }
                }
            }
        },
        "/bookings/{bookingId}/cancel": {
            "post": {
                "description": "Доступно только роли user. Пользователь может отменить только свою бронь. Операция идемпотентна: повторный вызов на уже отменённой брони не является ошибкой и возвращает 200 с актуальным состоянием брони (status: cancelled). При попытке отменить чужую бронь — 403. При отсутствии брони с указанным ID — 404.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Bookings"
                ],
                "summary": "Отменить бронь (только своя бронь, только user)",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Идентификатор брони",
                        "name": "bookingId",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Бронь отменена (или уже была отменена ранее)",
                        "schema": {
                            "$ref": "#/definitions/internal_features_bookings_transport_http.BookingDTOResponse"
                        }
                    },
                    "401": {
                        "description": "Не авторизован",
                        "schema": {
                            "$ref": "#/definitions/backend-assignment-avito_internal_core_domain.CustomError"
                        }
                    },
                    "403": {
                        "description": "Не своя бронь или роль не user",
                        "schema": {
                            "$ref": "#/definitions/backend-assignment-avito_internal_core_domain.CustomError"
                        }
                    },
                    "404": {
                        "description": "Бронь не найдена",
                        "schema": {
                            "$ref": "#/definitions/backend-assignment-avito_internal_core_domain.CustomError"
                        }
                    },
                    "500": {
                        "description": "Внутренняя ошибка сервера",
                        "schema": {
                            "$ref": "#/definitions/backend-assignment-avito_internal_core_domain.CustomError"
                        }
                    }
                }
            }
        },
        "/dummyLogin": {
            "post": {
                "description": "Выдаёт тестовый JWT для указанной роли (admin / user). Для каждой роли возвращается фиксированный UUID пользователя: один и тот же UUID для всех запросов с ролью admin и один и тот же UUID для роли user. Это обеспечивает стабильность при тестировании сценариев, требующих проверки владельца брони.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Auth"
                ],
                "summary": "Получить тестовый JWT по роли",
                "parameters": [
                    {
                        "description": "DummyLogin тело запроса",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/internal_features_auth_transport_http.DummyLoginDTO"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Тестовый токен",
                        "schema": {
                            "$ref": "#/definitions/internal_features_auth_transport_http.DummyLoginDTOResponse"
                        }
                    },
                    "400": {
                        "description": "Неверный запрос (недопустимое значение роли)",
                        "schema": {
                            "$ref": "#/definitions/backend-assignment-avito_internal_core_domain.CustomError"
                        }
                    },
                    "500": {
                        "description": "Внутренняя ошибка сервера",
                        "schema": {
                            "$ref": "#/definitions/backend-assignment-avito_internal_core_domain.InternalError"
                        }
                    }
                }
            }
        },
        "/login": {
            "post": {
                "description": "Авторизует пользователя по email и паролю, возвращает JWT. Реализация этого эндпоинта является дополнительным заданием. Для авторизации в рамках обязательной части используйте /dummyLogin. Доступен без авторизации.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Auth"
                ],
                "summary": "Авторизация по email и паролю",
                "parameters": [
                    {
                        "description": "тело запроса",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/internal_features_auth_transport_http.LoginDTO"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Успешная авторизация",
                        "schema": {
                            "$ref": "#/definitions/internal_features_auth_transport_http.LoginDTOResponse"
                        }
                    },
                    "401": {
                        "description": "Неверные учётные данные",
                        "schema": {
                            "$ref": "#/definitions/backend-assignment-avito_internal_core_domain.CustomError"
                        }
                    },
                    "500": {
                        "description": "Внутренняя ошибка сервера",
                        "schema": {
                            "$ref": "#/definitions/backend-assignment-avito_internal_core_domain.InternalError"
                        }
                    }
                }
            }
        },
        "/register": {
            "post": {
                "description": "Создаёт нового пользователя и возвращает его данные. Реализация этого эндпоинта является дополнительным заданием. Для авторизации в рамках обязательной части используйте /dummyLogin. Доступен без авторизации.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Auth"
                ],
                "summary": "Регистрация пользователя",
                "parameters": [
                    {
                        "description": "тело запроса",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/internal_features_auth_transport_http.RegisterDTO"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Пользователь создан",
                        "schema": {
                            "$ref": "#/definitions/internal_features_auth_transport_http.RegisterDTOResponse"
                        }
                    },
                    "400": {
                        "description": "Неверный запрос или email уже занят",
                        "schema": {
                            "$ref": "#/definitions/backend-assignment-avito_internal_core_domain.CustomError"
                        }
                    },
                    "500": {
                        "description": "Внутренняя ошибка сервера",
                        "schema": {
                            "$ref": "#/definitions/backend-assignment-avito_internal_core_domain.InternalError"
                        }
                    }
                }
            }
        },
