                "message": {
                    "type": "string",
                    "example": "invalid request"
                }
            }
        },
        "backend-assignment-avito_internal_core_domain.InternalError": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "string",
                    "enum": [
                        "INTERNAL_ERROR"
                    ]
                },
                "message": {
                    "type": "string",
                    "example": "internal server error"
                }
            }
        },
        "internal_features_auth_transport_http.DummyLoginDTO": {
