        "/rooms/{roomId}/schedule/create": {
            "post": {
                "description": "Доступно только роли admin. Расписание можно создать только один раз для каждой переговорки. Поле daysOfWeek должно содержать значения от 1 до 7 (1=Пн, 7=Вс). При передаче значений вне этого диапазона возвращается 400.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Schedules"
                ],
                "summary": "Создать расписание переговорки (только admin, только один раз). Длительность слота 30 мин. После создания расписание изменить нельзя.",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Идентификатор переговорки",
                        "name": "roomId",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Расписание сохранено",
                        "schema": {
                            "$ref": "#/definitions/internal_features_schedules_transport_http.ScheduleDTOResponse"
                        }
                    },
                    "400": {
                        "description": "Неверный запрос (в т.ч. недопустимые значения daysOfWeek)",
                        "schema": {
                            "$ref": "#/definitions/backend-assignment-avito_internal_core_domain.CustomError"
                        }
                    },
                    "401": {
                        "description": "Не авторизован",
                        "schema": {
                            "$ref": "#/definitions/backend-assignment-avito_internal_core_domain.CustomError"
                        }
                    },
                    "403": {
                        "description": "Доступ запрещён (требуется роль admin)",
                        "schema": {
                            "$ref": "#/definitions/backend-assignment-avito_internal_core_domain.CustomError"
                        }
                    },
                    "404": {
                        "description": "Переговорка не найдена",
                        "schema": {
                            "$ref": "#/definitions/backend-assignment-avito_internal_core_domain.CustomError"
                        }
                    },
                    "409": {
                        "description": "Расписание для переговорки уже создано, изменение не допускается",
                        "schema": {
                            "$ref": "#/definitions/backend-assignment-avito_internal_core_domain.CustomError"
                        }
                    },
                    "500": {
                        "description": "Внутренняя ошибка сервера",
                        "schema": {
                            "$ref": "#/definitions/backend-assignment-avito_internal_core_domain.InternalError"
                        }
                    }
                }
            }
        },
        "/rooms/{roomId}/slots/list": {
            "get": {
                "description": "Возвращает слоты, не занятые активной бронью, для указанной переговорки на указанную дату. Все даты и время передаются и возвращаются в UTC. Параметр date является обязательным; при его отсутствии возвращается 400. Если у переговорки нет расписания — возвращается пустой список (переговорка считается всегда недоступной).",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Slots"
                ],
                "summary": "Список доступных для бронирования слотов по переговорке и дате (admin и user). Наиболее нагруженный эндпоинт.",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Идентификатор переговорки",
                        "name": "roomId",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Дата в формате ISO 8601 (например: 2024-06-10). Обязательный параметр; при отсутствии — 400",
                        "name": "date",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Список доступных слотов (не занятых активной бронью). Пустой список, если у переговорки нет расписания или на эту дату нет слотов.",
                        "schema": {
                            "$ref": "#/definitions/internal_features_slots_transport_http.SlotsDTOResponse"
                        }
                    },
                    "400": {
                        "description": "Неверный запрос (отсутствует или некорректен параметр date)",
                        "schema": {
                            "$ref": "#/definitions/backend-assignment-avito_internal_core_domain.CustomError"
                        }
                    },
                    "401": {
                        "description": "Не авторизован",
                        "schema": {
                            "$ref": "#/definitions/backend-assignment-avito_internal_core_domain.CustomError"
                        }
                    },
                    "404": {
                        "description": "Переговорка не найдена",
                        "schema": {
                            "$ref": "#/definitions/backend-assignment-avito_internal_core_domain.CustomError"
                        }
                    },
                    "500": {
                        "description": "Внутренняя ошибка сервера",
                        "schema": {
                            "$ref": "#/definitions/backend-assignment-avito_internal_core_domain.InternalError"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "backend-assignment-avito_internal_core_domain.CustomError": {
            "type": "object",
